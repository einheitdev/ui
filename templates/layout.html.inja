<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {# Tells the UA to use dark scrollbars / form controls during the
     navigation moment before our CSS lands. Eliminates the white
     flash on full-page transitions. Light-theme users still see a
     brief dark background; reading the einheit_theme cookie here
     would fix that and is a follow-up. #}
  <meta name="color-scheme" content="dark light">
  <style>
    html { background: #101010; color: #f6fafa; }
  </style>
  {# Render-blocking inline script: reads the pinned-sidebar
     preference from localStorage and stamps it onto <html>
     before the body parses. CSS then keys off the html-level
     attribute so first paint already has the correct rail
     width — no animation flash on hx-boost'd page swaps. #}
  <script>
    try {
      if (localStorage.getItem('einheit:sidebar:pinned') === '1') {
        document.documentElement.dataset.sidebarPinned = 'true';
      }
    } catch (e) { /* private mode — fall through to default */ }
  </script>
  <title>{{ meta.title | default("einheit") }}</title>
  <link rel="stylesheet" href="/assets/base.css">
  <link rel="stylesheet" href="/assets/uplot.min.css">
  <link rel="stylesheet" href="/theme.css">
  {# htmx + ws-ext + uPlot stay in <head> with defer — they
     bootstrap once per browser session, not per navigation.
     Per-page bootstrap (sidebar.js, plot.js) sits at body
     bottom so hx-boost re-runs them after each swap. #}
  <script src="/assets/htmx.min.js" defer></script>
  <script src="/assets/htmx-ext-ws.js" defer></script>
  <script src="/assets/uplot.min.js" defer></script>
</head>
<body class="app-shell" hx-ext="ws" ws-connect="/events"
      hx-boost="true"
      hx-target="main.app-main"
      hx-select="main.app-main"
      hx-swap="outerHTML">
  {% include "partials/sidebar" %}
  <main class="app-main">
    <!--EINHEIT_BODY-->
  </main>
  <div id="toasts" class="toast-stack" aria-live="polite"
       aria-atomic="false"></div>
  <script src="/assets/sidebar.js"></script>
  <script src="/assets/plot.js"></script>
  <script src="/assets/copy.js"></script>
  <script src="/assets/toasts.js"></script>
</body>
</html>
