{# Card partial. Required: title (string), body (raw HTML).
   Optional: semantic ("good"|"warn"|"bad"|"info").
   For OOB swap targeting, wrap the card externally:
     <div id="my-card">{% include "partials/card" %}</div>
#}
<section class="card{% if semantic %} card-{{ semantic }}{% endif %}">
  <h2 class="card-title">{{ title }}</h2>
  <div class="card-body">
    {{ body }}
  </div>
</section>
